              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer"
                    },
                    "pollId": {
                      "type": "integer"
                    },
                    "optionId": {
                      "type": "integer"
                    },
                    "voterId": {
                      "type": "integer"
                    }
                  }
                },
                "example": {
                  "id": 101,
                  "pollId": 7,
                  "optionId": 13,
                  "voterId": 55
                }
              }
            }
          },
          "400": {
            "description": "Invalid input or poll closed",
            "content": {
