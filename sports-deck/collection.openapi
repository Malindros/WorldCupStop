    "/api/polls/{id}/vote": {
      "post": {
        "summary": "Vote in poll",
        "description": "Cast a vote for an option in an open poll. One vote per user per poll.",
        "tags": [
          "Polls"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
