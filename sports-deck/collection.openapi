        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "optionId"
                ],
                "properties": {
                  "optionId": {
                    "type": "integer",
                    "description": "ID of the poll option to vote for"
                  }
                }
              },
              "example": {
                "optionId": 13
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Vote recorded",
