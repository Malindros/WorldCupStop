          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "label"
                ],
                "properties": {
                  "label": {
                    "type": "string",
                    "description": "Option label (user-visible)",
                    "maxLength": 500
                  },
                  "metadata": {
                    "type": "object",
                    "nullable": true,
                    "description": "Optional metadata object stored with the option"
                  }
                }
              },
              "example": {
